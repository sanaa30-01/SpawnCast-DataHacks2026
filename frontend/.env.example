# Copy to .env in this folder.

# Public Mapbox token (starts with pk.) — create at https://account.mapbox.com/access-tokens/
# Never commit a real token; copy this file to .env and set VITE_MAPBOX_TOKEN there.
VITE_MAPBOX_TOKEN=

# FastAPI base URL (no trailing slash). Optional: overrides the dev default (Vite proxy at /spawncast-api).
# Set to empty string to force offline mock map/data.
# VITE_API_BASE_URL=http://127.0.0.1:8000
